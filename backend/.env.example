# Postgres connection string (Neon, Supabase, or any Postgres).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Separate Postgres database used by the test suite (e.g. a Neon branch).
# The suite resets data, so this MUST NOT be the same as DATABASE_URL.
TEST_DATABASE_URL="postgresql://user:password@host/dbname_test?sslmode=require"

# Environment: development | test | production (controls strict checks + log verbosity)
NODE_ENV=development

# Secret used to sign JWTs — MUST be a long random string (>= 32 chars in production)
JWT_SECRET="change-me-to-a-long-random-secret"
# Access-token lifetime (e.g. 15m, 12h, 7d)
JWT_EXPIRES_IN=7d

# API server port
PORT=5001

# Public URL of the frontend — used for the email verification link + CORS allow-list.
APP_URL=http://localhost:5173
# Extra allowed CORS origins (comma-separated). Localhost is always allowed in dev.
# CORS_ORIGIN=https://tickworth.example

# Email (Gmail SMTP). SMTP_PASS is a 16-char Google App Password (needs 2-Step Verification).
# If unset, verification links are logged to the server console instead of emailed.
SMTP_USER="you@gmail.com"
SMTP_PASS="your-16-char-app-password"

# TEMPORARY: set to "true" to verify new customers on sign-up WITHOUT sending an email.
# Use this when the host blocks outbound SMTP (e.g. Railway), so registration works.
# Set back to "false" (or remove) once email is delivered via an HTTP provider.
AUTO_VERIFY_CUSTOMERS="false"

# Cloudinary — hosts product/colour images. Get these from the Cloudinary Dashboard (free).
# The API secret stays server-side only (never commit it / never expose it to the frontend).
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
