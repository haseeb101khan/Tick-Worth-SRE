# Postgres connection string (Neon, Supabase, or any Postgres).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Separate Postgres database used by the test suite (e.g. a Neon branch).
# The suite resets data, so this MUST NOT be the same as DATABASE_URL.
TEST_DATABASE_URL="postgresql://user:password@host/dbname_test?sslmode=require"

# Secret used to sign JWTs — change to a long random string
JWT_SECRET="change-me-to-a-long-random-secret"

# API server port
PORT=5001
